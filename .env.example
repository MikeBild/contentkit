# Production template. Local development uses .env.defaults automatically.
NODE_ENV=production
HOST=127.0.0.1
PORT=4050
CONTENTKIT_PUBLIC_URL=https://contentkit-api.example.com
CONTENTKIT_BOOTSTRAP_API_KEY=replace-with-a-long-random-secret
CONTENTKIT_KEY_PEPPER=replace-with-a-different-long-random-secret
CONTENTKIT_PREVIEW_SECRET=replace-with-a-third-long-random-secret
CONTENTKIT_SESSION_SECRET=replace-with-an-independent-reader-session-secret
# MCP uses the same scoped principals as REST. OAuth tokens, browser sessions,
# CSRF values and upstream-login state use this independent secret.
CONTENTKIT_MCP_ENABLED=true
CONTENTKIT_MCP_SESSION_TTL_MS=1800000
CONTENTKIT_MCP_MAX_SESSIONS=1000
CONTENTKIT_MCP_ELICITATION_TIMEOUT_MS=300000
CONTENTKIT_OAUTH_SECRET=replace-with-an-independent-oauth-secret
CONTENTKIT_OAUTH_ALLOWED_SCOPES=mcp:read,mcp:authoring,mcp:admin
CONTENTKIT_OAUTH_DCR_ENABLED=true
# The only browser-provider contract. Protocols: api_key, token_bridge, oidc.
# Keep token-bridge trust data and OIDC client_secret values outside version control.
CONTENTKIT_OAUTH_PROVIDERS=[{"protocol":"api_key","id":"api-key","label":"ContentKit API key"}]
SUPABASE_URL=https://supabase.example.com
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://contentkit:replace-with-database-password@127.0.0.1:5432/contentkit
CONTENTKIT_STORAGE_BUCKET=contentkit
# Optional legacy all-events fallback; prefer managed per-site webhooks.
CONTENTKIT_WEBHOOK_URL=
CONTENTKIT_WEBHOOK_SECRET=
CONTENTKIT_TURNSTILE_SECRET=
CONTENTKIT_TRUST_PROXY=1
CONTENTKIT_MAX_BODY_BYTES=26214400
CONTENTKIT_BUILD_CONCURRENCY=1
CONTENTKIT_DECK_BUILD_CONCURRENCY=1
CONTENTKIT_DECK_BUILD_QUEUE_MAX=8
CONTENTKIT_DECK_BUILD_TIMEOUT_MS=120000
CONTENTKIT_DECK_QUEUE_TIMEOUT_MS=120000
CONTENTKIT_DECK_CACHE_MAX=32
CONTENTKIT_DECK_JOBS_MAX=8
CONTENTKIT_DECK_JOB_TTL_MS=600000
# CONTENTKIT_DECK_WORK_DIR=/var/cache/contentkit/decks
# CONTENTKIT_SLIDEV_CLI=/opt/contentkit/node_modules/@slidev/cli/bin/slidev.mjs
CONTENTKIT_PRODUCT_STATS_RETENTION_DAYS=400
# Optional privacy-bounded product usage telemetry. Generate a unique secret;
# never share it with another ContentKit secret or another product.
CONTENTKIT_USAGE_TELEMETRY_ENABLED=false
CONTENTKIT_USAGE_HMAC_SECRET=
CONTENTKIT_USAGE_RETENTION_DAYS=90
CONTENTKIT_WEBHOOK_POLL_MS=5000
LOG_LEVEL=info
CONTENTKIT_DEPLOYMENT_ENVIRONMENT=production
